# Split.io API Configuration
# Set this to your Split.io API base URL
# Default: https://api.split.io (public Split.io)
# For custom deployments, use your custom domain
SPLIT_API_BASE=https://api.split.io

# Harness API Configuration
# Set this to your Harness instance URL
# Default: https://app.harness.io
HARNESS_API_BASE=https://app.harness.io

# Logging
# Enable verbose logging for debugging
# Default: false
VERBOSE=false

# Development Server
# Port for serve.js development server
# Default: 8000
PORT=8000
